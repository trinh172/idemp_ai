<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Idempotency Test Report</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
         background: #f5f7fa; margin: 0; padding: 24px; color: #1a1a2e; }
  h1   { font-size: 1.6rem; margin-bottom: 4px; }
  .meta { color: #666; font-size: 0.9rem; margin-bottom: 24px; }
  .summary { display: flex; gap: 16px; margin-bottom: 32px; }
  .stat { background: #fff; border-radius: 10px; padding: 16px 24px;
          box-shadow: 0 1px 4px rgba(0,0,0,.08); text-align: center; }
  .stat .num  { font-size: 2rem; font-weight: 700; }
  .stat .label{ font-size: .8rem; color: #888; margin-top: 4px; }
  .pass { color: #16a34a; }
  .fail { color: #dc2626; }
  .error{ color: #d97706; }
  table { width: 100%; border-collapse: collapse; background: #fff;
          border-radius: 10px; overflow: hidden;
          box-shadow: 0 1px 4px rgba(0,0,0,.08); }
  th { background: #f1f5f9; padding: 12px 16px; text-align: left;
       font-size: .8rem; text-transform: uppercase; color: #64748b; }
  td { padding: 12px 16px; border-top: 1px solid #f1f5f9; font-size: .9rem; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 99px;
           font-size: .78rem; font-weight: 600; }
  .badge-pass  { background: #dcfce7; color: #16a34a; }
  .badge-fail  { background: #fee2e2; color: #dc2626; }
  .badge-error { background: #fef3c7; color: #d97706; }
  details { margin-top: 6px; }
  summary { cursor: pointer; color: #3b82f6; font-size: .82rem; }
  pre { background: #f8fafc; border-radius: 6px; padding: 10px;
        font-size: .8rem; overflow-x: auto; margin: 6px 0 0; }
</style>
</head>
<body>
<h1>Idempotency Test Report</h1>
<div class="meta">Generated: {{ generated_at }} &nbsp;|&nbsp; Endpoint: <code>{{ endpoint }}</code></div>

<div class="summary">
  <div class="stat"><div class="num">{{ total }}</div><div class="label">Total</div></div>
  <div class="stat"><div class="num pass">{{ passed }}</div><div class="label">Passed</div></div>
  <div class="stat"><div class="num fail">{{ failed }}</div><div class="label">Failed</div></div>
  <div class="stat"><div class="num error">{{ errored }}</div><div class="label">Error</div></div>
</div>

<table>
  <thead>
    <tr>
      <th>#</th><th>Scenario</th><th>Description</th>
      <th>Status</th><th>Calls</th><th>Details</th>
    </tr>
  </thead>
  <tbody>
    {% for r in results %}
    <tr>
      <td>{{ loop.index }}</td>
      <td><code>{{ r.scenario }}</code></td>
      <td>{{ r.description }}</td>
      <td>
        {% if r.status == "PASS" %}
          <span class="badge badge-pass">PASS</span>
        {% elif r.status == "FAIL" %}
          <span class="badge badge-fail">FAIL</span>
        {% else %}
          <span class="badge badge-error">ERROR</span>
        {% endif %}
      </td>
      <td>{{ r.api_results | length }}</td>
      <td>
        {% if r.failure_reason %}
          <span style="color:#dc2626">{{ r.failure_reason }}</span>
        {% endif %}
        {% if r.response_diff %}
          <details>
            <summary>Response diff</summary>
            <pre>{{ r.response_diff | tojson(indent=2) }}</pre>
          </details>
        {% endif %}
        {% if r.db_before and r.db_after %}
          <details>
            <summary>DB snapshot</summary>
            <pre>Before: mongo={{ r.db_before.mongo_count }}, mysql={{ r.db_before.mysql_count }}
After:  mongo={{ r.db_after.mongo_count }}, mysql={{ r.db_after.mysql_count }}</pre>
          </details>
        {% endif %}
        {% if r.api_results %}
          <details>
            <summary>Response codes &amp; times</summary>
            <pre>{% for c in r.api_results %}[{{ loop.index }}] HTTP {{ c.status_code }} — {{ c.response_time_ms }}ms
{% endfor %}</pre>
          </details>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</body>
</html>
